{
  "api_schema": {
    "info": {
      "description": "接收文档 URL，对文档进行解析并返回完整文档内容，不进行切分",
      "title": "chatdoc",
      "version": "1.0.0"
    },
    "openapi": "3.0.0",
    "paths": {
      "/v1/doc_parse": {
        "post": {
          "description": "接收文档 URL，对文档进行解析并返回完整文档内容，不进行切分",
          "summary": "解析文档返回内容",
          "operationId": "chatdoc",
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "upload_file_url": {
                      "description": "文件下载链接",
                      "type": "string"
                    }
                  },
                  "required": [
                    "upload_file_url"
                  ],
                  "type": "object"
                }
              }
            }
          },
          "responses": {
            "200": {
              "description": "解析成功",
              "content": {
                "application/json": {
                  "schema": {
                    "properties": {
                      "code": {
                        "type": "integer"
                      },
                      "data": {
                        "type": "string"
                      },
                      "msg": {
                        "type": "string"
                      }
                    },
                    "type": "object"
                  }
                }
              }
            }
          }
        }
      }
    },
    "servers": [
      {
        "url": "%s"
      }
    ]
  }
}