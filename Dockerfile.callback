ARG WANWU_ARCH

# 基于已构建的基础镜像
FROM --platform=linux/$WANWU_ARCH crpi-6pj79y7ddzdpexs8.cn-hangzhou.personal.cr.aliyuncs.com/wanwulite/callback-base:v0.4.2-bc4c9bf1

# 工作目录
WORKDIR /callback

# 复制 callback 代码
COPY ./callback .

EXPOSE 8669

# 使用 gunicorn 启动 Flask（加载 run.py 中的 app）
CMD ["sh", "start.sh"]